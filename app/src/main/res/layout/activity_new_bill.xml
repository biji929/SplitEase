<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- Custom Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="0dp">
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_logout"
                android:rotation="45"
                app:tint="@color/text_primary"
                android:padding="10dp"
                android:contentDescription="Close"
                tools:ignore="RtlHardcoded" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="New bill"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSave"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_alignParentRight="true"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/green_chip"
            app:cardElevation="0dp">
            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:text="Save"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/green_secondary"
                android:textAllCaps="false"
                android:paddingHorizontal="20dp"/>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnSplitBill">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Amount Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL AMOUNT (₱)"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText" />
                    <EditText
                        android:id="@+id/etAmount"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/input_border"
                        android:paddingHorizontal="20dp"
                        android:textSize="32sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:inputType="numberDecimal"
                        android:layout_marginBottom="12dp"
                        tools:ignore="HardcodedText" />
                    <TextView
                        android:id="@+id/tvEachPersonPays"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/green_mid"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bill Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BILL TITLE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                tools:ignore="HardcodedText" />
            <EditText
                android:id="@+id/etBillTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_border"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"
                android:importantForAutofill="no"
                tools:ignore="HardcodedText" />

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORY"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                tools:ignore="HardcodedText" />
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Selected Chip -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/chipFood"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/green_chip"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="🍕 Food"
                            android:textColor="@color/green_secondary"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />
                    </androidx.cardview.widget.CardView>
                    <!-- Normal Chips -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/chipTransport"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="🚗 Transport"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/chipStay"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="🏠 Stay"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/chipFun"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardElevation="0dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="🎮 Fun"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Split With -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPLIT WITH"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                tools:ignore="HardcodedText" />
            <LinearLayout
                android:id="@+id/layoutParticipants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <!-- Me Avatar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="48dp" android:layout_height="48dp"
                    app:cardCornerRadius="14dp" app:cardBackgroundColor="@color/brand_green"
                    app:cardElevation="0dp" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                        android:text="ME" android:textColor="@color/white" android:gravity="center" android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                </androidx.cardview.widget.CardView>
                <!-- Add Button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnAddPerson"
                    android:layout_width="48dp" android:layout_height="48dp"
                    app:cardCornerRadius="14dp" app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/btn_outline_rounded">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:text="+" android:textColor="@color/text_muted" android:textSize="24sp" android:gravity="center"
                            tools:ignore="HardcodedText" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Split Method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPLIT METHOD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                tools:ignore="HardcodedText" />
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSplitMethod"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/input_border">
                    <TextView android:id="@+id/tvSplitMethod"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Equal split"
                        android:textSize="16sp" android:textColor="@color/text_primary"
                        tools:ignore="HardcodedText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▼" android:textSize="12sp" android:textColor="@color/text_muted"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSplitBill"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:text="🤝 Split bill"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/btn_green_rounded"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="HardcodedText" />

</androidx.constraintlayout.widget.ConstraintLayout>