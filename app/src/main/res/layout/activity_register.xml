<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Back button - Increased to 48dp for accessibility touch target -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/green_chip"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackground"
                    android:src="@drawable/ic_back"
                    app:tint="@color/green_dark"
                    android:padding="12dp"
                    android:contentDescription="@string/back" />
            </androidx.cardview.widget.CardView>

            <!-- Changed title text to avoid duplicate speakable text with the action button -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_your_account"
                android:textSize="28sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/join_message"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp"/>

            <!-- Full Name -->
            <TextView
                android:id="@+id/labelFullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:labelFor="@+id/etFullName"/>

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_border"
                android:paddingHorizontal="20dp"
                android:inputType="textPersonName"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"
                android:importantForAutofill="no" />

            <!-- Email Address -->
            <TextView
                android:id="@+id/labelEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_address_label"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:labelFor="@+id/etEmail"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_border"
                android:paddingHorizontal="20dp"
                android:inputType="textEmailAddress"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"
                android:importantForAutofill="no" />

            <!-- Phone Number -->
            <TextView
                android:id="@+id/labelPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/phone_number_label"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:labelFor="@+id/etPhone"/>

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_border"
                android:paddingHorizontal="20dp"
                android:inputType="phone"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"
                android:importantForAutofill="no" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:id="@+id/labelPassword"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/password"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp"
                            android:labelFor="@+id/etPassword"/>

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_border"
                            android:paddingHorizontal="20dp"
                            android:inputType="textPassword"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:importantForAutofill="no" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/labelConfirm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/confirm"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp"
                            android:labelFor="@+id/etConfirmPassword"/>

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_border"
                            android:paddingStart="20dp"
                            android:paddingEnd="56dp"
                            android:inputType="textPassword"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:importantForAutofill="no" />
                    </LinearLayout>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginBottom="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_eye"
                    android:padding="12dp"
                    android:contentDescription="@string/toggle_password" />
            </FrameLayout>

            <!-- Terms checkbox - Removed minWidth/minHeight to fix touch target -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleX="1.2"
                android:scaleY="1.2"
                android:buttonTint="@color/green_secondary"
                android:checked="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/terms_agreement"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="4dp"
                android:labelFor="@id/cbTerms"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/create_account"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/btn_green_rounded"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/continue_with_google"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:background="@drawable/btn_outline_rounded"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:drawableStart="@drawable/ic_google"
                android:paddingStart="24dp"
                android:drawablePadding="-24dp"
                android:layout_marginBottom="32dp"
                tools:ignore="RtlSymmetry" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/already_have_account_v2"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sign_in_v2"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_secondary"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>